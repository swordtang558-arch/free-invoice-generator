# Public site URL (used for canonical links, sitemap, Open Graph). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Phase 2 placeholders (leave blank in Phase 1) ---
# Google Analytics measurement id, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# Google Search Console verification token (content of the meta tag)
NEXT_PUBLIC_GSC_VERIFICATION=
# Google AdSense publisher id, e.g. ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=
